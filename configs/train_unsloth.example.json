{
  "unsloth_disable_compile": true,
  "unsloth_fullgraph": false,
  "unsloth_compile_ignore_errors": true,
  "clear_unsloth_cache": true,
  "disable_torchdynamo": false,
  "disable_torch_compile": false,
  "dataset": "data/train.jsonl",
  "model": "Qwen/Qwen3-8B",
  "output_dir": "artifacts/runs/qwen3_8b_unsloth_grpo",
  "max_seq_length": 4096,
  "max_prompt_length": 3072,
  "max_completion_length": 1024,
  "enable_thinking": false,
  "load_in_4bit": true,
  "lora_r": 32,
  "learning_rate": 1e-05,
  "per_device_train_batch_size": 1,
  "gradient_accumulation_steps": 8,
  "num_train_epochs": 1.0,
  "num_generations": 4,
  "save_steps": 50,
  "logging_steps": 1,
  "warmup_steps": 0,
  "seed": 42,
  "trust_remote_code": true,
  "use_unsloth_gradient_checkpointing": true,
  "report_to": "none"
}
